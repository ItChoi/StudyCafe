# =============================================================================
# Docker Compose 비밀값 없는 설정 (.env 파일로 복사 후 사용)
# 시크릿(비밀번호, 계정)은 프로젝트 외부 파일로 별도 관리
# =============================================================================

# RDBMS
POSTGRES_SCHEMA=
POSTGRES_HOST=localhost
POSTGRESQL_CLIENT_PORT=5432
POSTGRESQL_SERVER_PORT=5432

# REDIS
REDIS_CLIENT_PORT=6379
REDIS_SERVER_PORT=6379

# =============================================================================
# 외부 시크릿 파일 설정 (한 번만 설정, 이후 자동 적용)
#
# ── Spring Boot ──────────────────────────────────────────────────────────────
# 파일: ~/.config/local/rdb/secrets.yml
# 내용 (Spring 프로퍼티 키 형식):
#   spring:
#     datasource:
#       username: your_db_user
#       password: your_db_password
#
# → application.yml의 spring.config.import 가 앱 시작 시 자동 로드
#
# ── IntelliJ + 환경 변수 ─────────────────────────────────────────────────────
# 파일: ~/.config/local/.env
# 내용 (KEY=VALUE 형식):
#   DEFAULT_USER=your_user
#   DEFAULT_PASSWORD=your_password
#   POSTGRES_ROOT=your_db_root
#
# IntelliJ 설정:
#   Run Configuration → Modify options → Environment variables
#   → "Load variables from .env file" 에 ~/.config/local/.env 경로 입력
#
# ── Docker Compose ───────────────────────────────────────────────────────────
# docker compose --env-file ~/.config/local/.env up
# =============================================================================
